// Prisma schema — defines database tables for the portfolio backend.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) — used at runtime
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) — used by Prisma Migrate
  directUrl = env("DIRECT_URL")
}

/// Contact form submissions from the portfolio site
model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Admin profile linked to a Supabase Auth user (auth.users id)
model Profile {
  id         String   @id @default(uuid())
  authUserId String   @unique
  name       String
  email      String
  role       String   @default("Admin")
  createdAt  DateTime @default(now())
}

/// Tracks login attempts by IP for rate limiting (Phase 6)
model LoginAttempt {
  id            String    @id @default(uuid())
  ipAddress     String    @unique
  attempts      Int       @default(0)
  lastAttemptAt DateTime  @default(now())
  blockedUntil  DateTime?
}
